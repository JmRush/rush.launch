# Optional: Custom SQLite database path (defaults to server/data/sqlite.db)
# DATABASE_URL=server/data/sqlite.db

# API server (defaults: port 3001, CORS allows localhost:3000)
# API_PORT=3001
# CORS_ORIGIN=http://localhost:3000

# Frontend - API base URL (for client-side fetches)
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Admin login credentials
#ADMIN_EMAIL=admin@example.com
#ADMIN_PASSWORD=admin


#Dockerhub credentials
#DOCKERHUB_USERNAME=your_dockerhub_username
#DOCKERHUB_PAT=your_dockerhub_pat